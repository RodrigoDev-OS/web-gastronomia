---
// 🚨 LE DECIMOS A ASTRO QUE ESTA PÁGINA SE PROCESA EN VIVO EN EL SERVIDOR
export const prerender = false;

// 1. Conectamos con nuestro puente de Supabase
import { supabase } from '../../lib/supabase';

// 2. Capturamos el parámetro 'slug' directamente desde la URL de la página
const { slug } = Astro.params;

// 3. Consultamos a Supabase pidiendo los datos únicamente del plato cliqueado
const { data: receta, error } = await supabase
  .from('recetas')
  .select('*')
  .eq('slug', slug) // Filtramos donde la columna 'slug' sea igual al de la URL
  .single();        // Le pedimos que traiga un solo objeto, no un arreglo

// Si el plato no existe en la base de datos o hay un error, redirigimos al recetario
if (error || !receta) {
  return Astro.redirect('/recetas');
}
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{receta.titulo} - Perú En Su Mesa</title>
</head>
<body class="bg-amber-50 text-stone-800 min-h-screen">

    <nav class="bg-white shadow-sm border-b border-amber-100">
        <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2 font-bold text-amber-700 text-xl">
                <span>🍽️ Perú En Su Mesa</span>
            </div>
            <div class="flex gap-4 font-medium">
                <a href="/" class="text-stone-500 hover:text-amber-700 transition-colors">Inicio</a>
                <a href="/recetas" class="text-amber-700 border-b-2 border-amber-700 pb-1">Recetas</a>
            </div>
        </div>
    </nav>

    <main class="max-w-3xl mx-auto px-4 py-12">
        <a href="/recetas" class="inline-flex items-center gap-2 text-amber-700 hover:text-amber-800 font-medium mb-6 transition-colors">
            ← Volver al recetario
        </a>

        <div class="h-64 md:h-96 rounded-2xl overflow-hidden shadow-lg mb-8 bg-stone-200">
            <img 
                src={receta.imagen_url} 
                alt={receta.titulo} 
                class="w-full h-full object-cover" 
            />
        </div>

        <h1 class="text-3xl md:text-5xl font-extrabold text-stone-900 mb-6">
            {receta.titulo}
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-1 bg-white p-6 rounded-2xl shadow-sm border border-amber-100">
                <h2 class="text-xl font-bold text-stone-900 border-b pb-2 mb-4">Ingredientes</h2>
                <p class="text-stone-600 leading-relaxed whitespace-pre-line">
                    {receta.ingredientes}
                </p>
            </div>

            <div class="md:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-amber-100">
                <h2 class="text-xl font-bold text-stone-900 border-b pb-2 mb-4">Preparación paso a paso</h2>
                <p class="text-stone-600 leading-relaxed whitespace-pre-line">
                    {receta.preparacion}
                </p>
            </div>
        </div>
    </main>

</body>
</html>